generator client {
    provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model SeenSlackMessages {
    id String @id

    @@map("seen_slack_messages")
}

model Task {
    id String @id @default(cuid())
    threadId String @unique
    sessionId String
    branchName String
    status String @default("pending")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("task")
}
